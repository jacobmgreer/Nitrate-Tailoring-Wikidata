SELECT ?item ?prop ?value ?date WHERE {
  VALUES ?prop { 
    wdt:P2019 ## AllMovie film database
    wdt:P3857 ## cinenacional.com (from Argentina)
    wdt:P4084 ## MyAnimeList
    wdt:P4657 ## The Numbers
    wdt:P5233 ## Filmow (from Brazil)
    wdt:P10266 ## AdoraCinema (from Braszil)
    wdt:P12309 ## Moviefone
    wdt:P12426 ## Sundance Institute Digital Archive
  }
  ?item ?prop ?value;
        schema:dateModified ?date.
}